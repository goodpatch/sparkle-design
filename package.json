{
  "name": "sparkle-design",
  "version": "0.1.0",
  "private": true,
  "author": "Goodpatch Inc. <sparkle-design@goodpatch.com>",
  "type": "module",
  "description": "Sparkle DesignのReactコンポーネントライブラリ",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwind",
    "sparkle-design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goodpatch/sparkle-ui"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:ai-analyze": "npm test > test-output.log 2>&1 && echo 'Test results saved to test-output.log for AI analysis'",
    "test:failures": "npm test > test-output.log 2>&1 && grep -A 5 -B 5 'FAIL\\|✗\\|Error' test-output.log > test-failures.log && echo 'Test failures extracted to test-failures.log'",
    "test:cleanup": "rm -f test-output.log test-failures.log test-*.log",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir public/storybook",
    "build:css": "npx sparkle-design-cli",
    "build:registry": "shadcn build",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "npx lightningcss --version || true",
    "build:package": "rm -rf dist && tsc -p tsconfig.build.json && cp src/app/globals.css dist/globals.css && cp src/app/sparkle-design.css dist/sparkle-design.css",
    "format": "prettier -w \"**/*.{js,ts,tsx,css,md,json}\""
  },
  "dependencies": {
    "@figma/code-connect": "^1.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "15.3.1",
    "radix-ui": "^1.4.2",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^2.5.0",
    "storybook": "^8.6.14",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-actions": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/experimental-addon-test": "^8.6.14",
    "@storybook/experimental-nextjs-vite": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@tailwindcss/postcss": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/browser": "^3.0.9",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^0.12.0",
    "playwright": "^1.51.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.9"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/globals.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./globals.css": "./dist/globals.css",
    "./sparkle-design.css": "./dist/sparkle-design.css"
  },
  "files": [
    "dist"
  ]
}
