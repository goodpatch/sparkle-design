{
  "name": "@goodpatch/sparkle-design",
  "version": "1.0.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "author": "Goodpatch Inc. <sparkle-design@goodpatch.com>",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Sparkle DesignのReactコンポーネントライブラリ",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwind",
    "sparkle-design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goodpatch/sparkle-design"
  },
  "homepage": "https://sparkle-design.goodpatch.com",
  "bugs": {
    "url": "https://github.com/goodpatch/sparkle-design/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:ai-analyze": "npm test > test-output.log 2>&1 && echo 'Test results saved to test-output.log for AI analysis'",
    "test:failures": "npm test > test-output.log 2>&1 && grep -A 5 -B 5 'FAIL\\|✗\\|Error' test-output.log > test-failures.log && echo 'Test failures extracted to test-failures.log'",
    "test:cleanup": "rm -f test-output.log test-failures.log test-*.log",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir public/storybook",
    "build:css": "npx --yes sparkle-design-cli generate",
    "build:registry": "shadcn build",
    "build:registry:full": "make registry",
    "build:registry:merge": "node scripts/merge-registry.mjs",
    "build:registry:vercel": "bash scripts/build-registry-vercel.sh",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "npx lightningcss --version || true",
    "build:package": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "prettier --config ./.prettierrc -w \"**/*.{js,ts,tsx,css,md,json}\"",
    "format:check": "prettier --config ./.prettierrc --check \"**/*.{js,ts,tsx,css,md,json}\"",
    "lint:fix": "next lint --fix",
    "lint:check": "next lint",
    "type-check": "tsc --noEmit",
    "update:public-domain": "node scripts/update-public-domain.mjs"
  },
  "dependencies": {
    "@figma/code-connect": "^1.3.4",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^11.0.0",
    "lucide-react": "^0.487.0",
    "radix-ui": "^1.4.2",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-hook-form": "^7.63.0",
    "shadcn": "^2.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/blocks": "^8.6.18",
    "@storybook/experimental-addon-test": "^8.6.18",
    "@storybook/experimental-nextjs-vite": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/postcss": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/browser": "^3.0.9",
    "@vitest/coverage-v8": "^3.0.9",
    "axe-core": "^4.10.3",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-storybook": "^0.12.0",
    "next": "15.5.15",
    "playwright": "^1.51.1",
    "prettier": "^3.6.2",
    "storybook": "^8.6.18",
    "tailwindcss": "^4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5",
    "vite-plugin-storybook-nextjs": "^3.2.4",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "overrides": {
      "vite-plugin-storybook-nextjs": "^3.2.4"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
